{
	email {$ACME_EMAIL:admin@campuscloud.io}
}

# Content domain — Python vector server
{$CONTENT_DOMAIN:content.campuscloud.io} {
	reverse_proxy 127.0.0.1:8443
}

# OOB domain — Interactsh handles its own DNS; Caddy fronts HTTP(S)
# Wildcard certs require DNS-01 challenge. For now, proxy plain HTTP
# and let Interactsh handle HTTPS if needed.
http://*.{$OOB_DOMAIN:oob.campuscloud.io} {
	reverse_proxy 127.0.0.1:80
}
